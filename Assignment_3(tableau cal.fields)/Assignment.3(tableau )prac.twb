      <aliases enabled='yes' />
      <column caption='Delivery Status' datatype='string' name='[Calculation_1493476270997504]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Delivery_Time_Min]&lt;=30 THEN &quot;fast&quot;&#13;&#10;ELSE &quot;delayed&quot;&#13;&#10;END' />
      </column>
      <column caption='Loss order' datatype='string' name='[Calculation_1493476272123905]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit]&lt; 0 THEN &quot;loss&quot;&#13;&#10;ELSE &quot;not loss&quot;&#13;&#10;END' />
      </column>
      <column caption='Product Rank' datatype='integer' name='[Calculation_1493476357103618]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Sales]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top N Filter' datatype='string' name='[Calculation_1493476358393859]' role='measure' type='nominal'>
