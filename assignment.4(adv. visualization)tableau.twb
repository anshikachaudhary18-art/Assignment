        </calculation>
      </column>
      <column caption='cf male' datatype='integer' name='[Calculation_0067963054252034]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Gender] = &quot;Male&quot; THEN 1 END' />
      </column>
      <column caption='cf female' datatype='integer' name='[Calculation_0067963054370819]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Gender] = &quot;Female&quot; THEN 1 END' />
      </column>
      <column caption='cf sun' datatype='integer' name='[Calculation_0067963060346884]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([Diagnosis]) THEN 1 ELSE 2 END' />
      </column>
      <column caption='cf sun 2' datatype='real' name='[Calculation_0067963413561365]' role='measure' type='quantitative'>
